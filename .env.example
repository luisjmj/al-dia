# Copia este archivo como ".env.local" y pega tus valores de Supabase.
# Supabase → Project Settings → Data API (o API).
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anon-publica

# Web Push: llave PÚBLICA VAPID (genera el par con `npx web-push generate-vapid-keys`).
# La privada NO va aquí: se guarda como secret de la Edge Function (VAPID_PRIVATE_KEY).
VITE_VAPID_PUBLIC_KEY=tu-llave-publica-vapid
